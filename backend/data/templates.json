    "constraints": ["(initial_conc * initial_water) % target_conc == 0", "target_conc > initial_conc"],
    "problem_template": "{{initial_conc}}\\%의 소금물 {{initial_water}}g이 있다. 이 소금물에서 물을 몇 g 증발시켜야 {{target_conc}}\\%의 소금물이 되는지 구하시오.",
    "answer_formula": { "type": "expression", "value": "initial_water - (initial_conc * initial_water / target_conc)" },
    "concepts": ["일차방정식의 활용", "농도"]
