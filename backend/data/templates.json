    "constraints": ["a > 0", "b < 0"],
    "problem_template": "두 수 $a, b$에 대하여 $|a| = {{a}}$, $|b| = {{-b}}$이고 $a > b$일 때, $a - b$의 값을 구하시오.",
    "answer_formula": { "type": "expression", "value": "a - b" },
    "concepts": ["절댓값", "유리수의 뺄셈"]
  },
  {
